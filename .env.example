# AI
GROQ_API_KEY=                    # Required. Get from console.groq.com

# Slack  
SLACK_BOT_TOKEN=                 # xoxb-... from api.slack.com/apps
SLACK_SIGNING_SECRET=            # From Slack app Basic Information page
SLACK_CHANNEL_OPS_ALERTS=#ops-alerts 
SLACK_CHANNEL_SECURITY=#security-alerts
SLACK_CHANNEL_RISK=#risk-alerts
SLACK_CHANNEL_ONBOARDING=#onboarding
MOCK_SLACK=true                  # Set false to use real Slack

# GitHub
GITHUB_TOKEN=                    # ghp_... Personal access token, repo scope
GITHUB_DEMO_REPO_OWNER=          # Your GitHub username
GITHUB_DEMO_REPO_NAME=flowsentrix-demo
MOCK_GITHUB=true                 # Set false to use real GitHub

# Email (Resend)
RESEND_API_KEY=                  # re_... from resend.com
EMAIL_FROM=onboarding@resend.dev # No domain verification needed for demo
EMAIL_DEMO_RECIPIENT=            # Your email for demo autopsy reports
MOCK_SMTP=true                   # Set false to use real email

# Database
DATABASE_URL=postgresql://flowsentrix:password@localhost:5432/flowsentrix

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
BASE_URL=http://localhost:3000   # Used in HITL email links
DEMO_INJECT_FAILURE_AT_STEP=4   # Set to trigger healing demo
NODE_ENV=development

# API Key Protection
API_KEY=                         # Protects action-triggering routes. Generate with: openssl rand -hex 32
